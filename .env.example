# Copy this file to .env and fill in the values
# cp .env.example .env

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=quickshop

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=quickshop-redis
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=quickshop-kafka:29092

# ── Service Discovery ────────────────────────────────────────────
EUREKA_URL=http://service-registry:8761/eureka/

# ── Distributed Tracing (Jaeger OTLP) ───────────────────────────
JAEGER_OTLP=http://quickshop-jaeger:4318/v1/traces

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=

# ── Grafana ──────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
